{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": [
      "error",
      {
        "vars": "all",
        "args": "after-used",
        "ignoreRestSiblings": true,
        "argsIgnorePattern": "^_"
      }
    ],
    "no-shadow": "error",
    "no-use-before-define": [
      "error",
      {
        "functions": false,
        "classes": true,
        "variables": true
      }
    ],
    "eqeqeq": [
      "error",
      "always",
      {
        "null": "ignore"
      }
    ],
    "curly": [
      "error",
      "all"
    ],
    "no-implicit-coercion": "error",
    "no-param-reassign": [
      "error",
      {
        "props": false
      }
    ],
    "no-throw-literal": "error",
    "prefer-promise-reject-errors": "error",
    "no-async-promise-executor": "error",
    "no-await-in-loop": "off",
    "no-return-await": "error",
    "require-await": "error",
    "no-console": "error",
    "no-debugger": "error",
    "no-alert": "error",
    "quotes": [
      "error",
      "single",
      {
        "avoidEscape": true
      }
    ],
    "semi": [
      "error",
      "always"
    ],
    "comma-dangle": [
      "error",
      "never"
    ],
    "object-shorthand": [
      "error",
      "always"
    ],
    "arrow-body-style": [
      "error",
      "as-needed"
    ],
    "prefer-arrow-callback": "error",
    "prefer-template": "error",
    "prefer-destructuring": [
      "error",
      {
        "array": false,
        "object": true
      }
    ],
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "no-useless-concat": "error",
    "no-useless-return": "error",
    "no-else-return": [
      "error",
      {
        "allowElseIf": false
      }
    ],
    "no-lonely-if": "error",
    "no-nested-ternary": "error",
    "no-unneeded-ternary": "error",
    "camelcase": [
      "error",
      {
        "properties": "never",
        "ignoreDestructuring": true
      }
    ],
    "new-cap": [
      "error",
      {
        "newIsCap": true,
        "capIsNew": true
      }
    ],
    "no-underscore-dangle": [
      "error",
      {
        "allowAfterThis": false,
        "allowAfterSuper": false,
        "enforceInMethodNames": false,
        "allow": []
      }
    ],
    "complexity": [
      "error",
      {
        "max": 12
      }
    ],
    "max-depth": [
      "error",
      {
        "max": 4
      }
    ],
    "max-lines-per-function": [
      "warn",
      {
        "max": 60,
        "skipBlankLines": true,
        "skipComments": true
      }
    ],
    "max-params": [
      "error",
      {
        "max": 5
      }
    ],
    "consistent-return": "error",
    "default-case": "error",
    "guard-for-in": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-proto": "error",
    "no-new-wrappers": "error",
    "radix": "error",
    "yoda": "error",
    "dot-notation": "error",
    "no-floating-decimal": "error",
    "no-multi-assign": "error",
    "no-sequences": "error",
    "no-void": "error",
    "operator-assignment": [
      "error",
      "always"
    ],
    "spaced-comment": [
      "error",
      "always"
    ],
    "no-duplicate-imports": "error",
    "no-useless-rename": "error",
    "symbol-description": "error",
    "class-methods-use-this": "off",
    "no-constructor-return": "error",
    "no-promise-executor-return": "error",
    "no-unreachable-loop": "error",
    "no-unsafe-optional-chaining": "error"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.js",
        "**/*.spec.js",
        "**/benchmark*.js"
      ],
      "rules": {
        "no-console": "off",
        "max-lines-per-function": "off",
        "max-params": "off"
      }
    }
  ]
}